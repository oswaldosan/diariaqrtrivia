# Copiá a .env y ajustá valores (misma base que el proyecto PHP)
DB_HOST=127.0.0.1
DB_USER=tu_usuario
DB_PASS=tu_clave
DB_NAME=tu_base
DB_PORT=3306

# Clave larga y aleatoria para firmar la cookie de sesión de trivia (JWT)
SESSION_SECRET=cambiame-por-algo-largo-y-secreto

# Opcional: mismo significado que en PHP
# LDL_DEV=1
