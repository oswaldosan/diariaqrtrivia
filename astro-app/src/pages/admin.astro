---
import Layout from '../layouts/Layout.astro';
import { APP_NAME } from '../lib/config';
import { escapeHtml } from '../lib/html';
import { renderDecor } from '../lib/decor';
import { getPool } from '../lib/db';

const section = Astro.url.searchParams.get('section') ?? 'dashboard';
const valid = ['dashboard', 'questions', 'participants'];
const sec = valid.includes(section) ? section : 'dashboard';

const flash = Astro.url.searchParams.get('flash');
const flashMsg = Astro.url.searchParams.get('msg');

const pool = getPool();

const [uRows] = await pool.query<{ c: number }[]>('SELECT COUNT(*) as c FROM users');
const [sRows] = await pool.query<{ c: number }[]>(
  'SELECT COUNT(*) as c FROM trivia_sessions WHERE completed_at IS NOT NULL'
);
const [wRows] = await pool.query<{ c: number }[]>(
  'SELECT COUNT(*) as c FROM trivia_sessions WHERE is_winner = 1'
);
const [avgRows] = await pool.query<{ a: string }[]>(
  'SELECT COALESCE(ROUND(AVG(score),1),0) as a FROM trivia_sessions WHERE completed_at IS NOT NULL'
);

const stats = {
  total_users: Number(uRows[0]?.c ?? 0),
  total_sessions: Number(sRows[0]?.c ?? 0),
  total_winners: Number(wRows[0]?.c ?? 0),
  avg_score: String(avgRows[0]?.a ?? '0'),
};

const [qRows] = await pool.query(
  `SELECT q.*, (SELECT COUNT(*) FROM answers a WHERE a.question_id = q.id) AS answer_count
   FROM questions q ORDER BY q.created_at DESC`
);
const questions = qRows as Record<string, unknown>[];

const [pRows] = await pool.query(
  `SELECT u.full_name, u.phone, ts.score, ts.total_questions, ts.is_winner, ts.completed_at
   FROM trivia_sessions ts JOIN users u ON u.id = ts.user_id
   WHERE ts.completed_at IS NOT NULL ORDER BY ts.completed_at DESC LIMIT 50`
);
const participants = pRows as Record<string, unknown>[];

const decorHtml = renderDecor(`admin-${sec}`);
---

<Layout title={`${APP_NAME} - Admin`} bodyClass={`page-admin page-admin-${sec}`}>
  <div set:html={decorHtml} />
  <div class="container admin">
    <div class="header">
      <div class="logo-wrap">
        <img src="/assets/logo.png" alt={APP_NAME} class="logo logo--trazo logo--sm" width="160" />
      </div>
      <h1>{APP_NAME} — Admin</h1>
    </div>
    {
      flash === 'ok' && (
        <div class="alert alert-success">Guardado.</div>
      )
    }
    {
      flash === 'error' && flashMsg && (
        <div class="alert alert-error">{decodeURIComponent(flashMsg)}</div>
      )
    }

    <div class="admin-nav">
      <a href="/admin?section=dashboard" class={sec === 'dashboard' ? 'active' : ''}>Dashboard</a>
      <a href="/admin?section=questions" class={sec === 'questions' ? 'active' : ''}>Preguntas</a>
      <a href="/admin?section=participants" class={sec === 'participants' ? 'active' : ''}>Participantes</a>
      <a href="/" style="margin-left:auto;">← Ir al sitio</a>
    </div>

    {
      sec === 'dashboard' && (
        <>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-number">{stats.total_users}</div>
              <div class="stat-label">Usuarios</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">{stats.total_sessions}</div>
              <div class="stat-label">Trivias</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">{stats.total_winners}</div>
              <div class="stat-label">Ganadores</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">{stats.avg_score}</div>
              <div class="stat-label">Puntaje Prom.</div>
            </div>
          </div>
          <div class="card">
            <h2>Últimos participantes</h2>
            {participants.length === 0 ? (
              <p style="color:#999;">Aún no hay participantes.</p>
            ) : (
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Nombre</th>
                      <th>Teléfono</th>
                      <th>Puntaje</th>
                      <th>Resultado</th>
                      <th>Fecha</th>
                    </tr>
                  </thead>
                  <tbody>
                    {participants.map((row) => (
                      <tr>
                        <td>{escapeHtml(String(row.full_name))}</td>
                        <td>{escapeHtml(String(row.phone))}</td>
                        <td>
                          {String(row.score)}/{String(row.total_questions)}
                        </td>
                        <td>
                          <span class={`badge ${row.is_winner ? 'badge-active' : 'badge-inactive'}`}>
                            {row.is_winner ? 'Ganador' : 'No ganó'}
                          </span>
                        </td>
                        <td>{String(row.completed_at)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </>
      )
    }

    {
      sec === 'questions' && (
        <>
          <div class="card edit-form" id="questionForm">
            <h3 id="formTitle">Nueva pregunta</h3>
            <form method="POST" action="/api/admin/save-question">
              <input type="hidden" name="action" value="save_question" />
              <input type="hidden" name="question_id" id="questionId" value="0" />
              <div class="form-group">
                <label>Texto de la pregunta <span class="required">*</span></label>
                <input type="text" name="question_text" id="questionText" placeholder="Ej: ¿Cuál es la capital de Honduras?" required />
              </div>
              <div id="answersContainer">
                <label style="font-weight:600;font-size:0.9rem;margin-bottom:8px;display:block;">
                  Respuestas (marcá la correcta)
                </label>
                {[0, 1, 2, 3].map((i) => (
                  <div class="answer-row">
                    <input type="text" name="answers" placeholder={`Respuesta ${i + 1}`} />
                    <label>
                      <input type="radio" name="correct_answer" value={String(i)} checked={i === 0} /> Correcta
                    </label>
                  </div>
                ))}
              </div>
              <div style="margin-top:16px;display:flex;gap:8px;">
                <button type="submit" class="btn btn-primary btn-small">Guardar</button>
                <button type="button" class="btn btn-secondary btn-small" id="btnResetForm">
                  Cancelar
                </button>
              </div>
            </form>
          </div>
          <div class="card">
            <h2>Preguntas ({questions.length})</h2>
            {questions.length === 0 ? (
              <p style="color:#999;">No hay preguntas.</p>
            ) : (
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Pregunta</th>
                      <th>Resp.</th>
                      <th>Estado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    {questions.map((q) => (
                      <tr>
                        <td>{String(q.id)}</td>
                        <td>{escapeHtml(String(q.question_text))}</td>
                        <td>{String(q.answer_count)}</td>
                        <td>
                          <span class={`badge ${q.is_active ? 'badge-active' : 'badge-inactive'}`}>
                            {q.is_active ? 'Activa' : 'Inactiva'}
                          </span>
                        </td>
                        <td>
                          <div class="actions">
                            <button
                              type="button"
                              class="btn btn-secondary btn-small btn-edit-q"
                              data-id={String(q.id)}
                              data-text={encodeURIComponent(String(q.question_text))}
                            >
                              Editar
                            </button>
                            <form method="POST" action="/api/admin/toggle" style="display:inline">
                              <input type="hidden" name="action" value="toggle" />
                              <input type="hidden" name="id" value={String(q.id)} />
                              <button type="submit" class="btn btn-secondary btn-small">
                                {q.is_active ? 'Desactivar' : 'Activar'}
                              </button>
                            </form>
                            <form method="POST" action="/api/admin/delete" style="display:inline" class="form-delete-q">
                              <input type="hidden" name="action" value="delete" />
                              <input type="hidden" name="id" value={String(q.id)} />
                              <button type="submit" class="btn btn-danger btn-small">
                                Eliminar
                              </button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
          <script>
            document.getElementById('btnResetForm')?.addEventListener('click', () => {
              document.getElementById('formTitle').textContent = 'Nueva pregunta';
              document.getElementById('questionId').value = '0';
              document.getElementById('questionText').value = '';
              document.querySelectorAll('#answersContainer input[type=text]').forEach((el) => {
                el.value = '';
              });
            });
            document.querySelectorAll('.btn-edit-q').forEach((btn) => {
              btn.addEventListener('click', () => {
                const id = btn.getAttribute('data-id');
                const raw = btn.getAttribute('data-text') || '';
                let text = '';
                try {
                  text = decodeURIComponent(raw);
                } catch {
                  text = raw;
                }
                document.getElementById('formTitle').textContent = 'Editar pregunta #' + id;
                document.getElementById('questionId').value = id;
                document.getElementById('questionText').value = text;
                document.getElementById('questionForm').scrollIntoView({ behavior: 'smooth' });
              });
            });
            document.querySelectorAll('.form-delete-q').forEach((f) => {
              f.addEventListener('submit', (e) => {
                if (!confirm('¿Eliminar?')) e.preventDefault();
              });
            });
          </script>
        </>
      )
    }

    {
      sec === 'participants' && (
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
            <h2 style="border-bottom:none;margin-bottom:0;padding-bottom:0;">Participantes</h2>
            <a href="/api/admin/export" class="btn btn-primary btn-small" style="width:auto;">↓ Exportar CSV</a>
          </div>
          {participants.length === 0 ? (
            <p style="color:#999;margin-top:16px;">Aún no hay participantes.</p>
          ) : (
            <div class="table-wrap" style="margin-top:16px;">
              <table>
                <thead>
                  <tr>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Puntaje</th>
                    <th>Resultado</th>
                    <th>Fecha</th>
                  </tr>
                </thead>
                <tbody>
                  {participants.map((row) => (
                    <tr>
                      <td>{escapeHtml(String(row.full_name))}</td>
                      <td>{escapeHtml(String(row.phone))}</td>
                      <td>
                        {String(row.score)}/{String(row.total_questions)}
                      </td>
                      <td>
                        <span class={`badge ${row.is_winner ? 'badge-active' : 'badge-inactive'}`}>
                          {row.is_winner ? 'Ganador' : 'No ganó'}
                        </span>
                      </td>
                      <td>{String(row.completed_at)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )
    }
  </div>
</Layout>
