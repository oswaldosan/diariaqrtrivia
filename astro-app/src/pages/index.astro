---
import Layout from '../layouts/Layout.astro';
import { APP_NAME } from '../lib/config';
import { renderDecor } from '../lib/decor';

const errRaw = Astro.cookies.get('ldl_reg_err')?.value;
let errors: Record<string, string> = {};
let old = { full_name: '', identity_number: '', email: '', phone: '' };
if (errRaw) {
  try {
    const parsed = JSON.parse(errRaw) as { errors: Record<string, string>; old: typeof old };
    errors = parsed.errors || {};
    old = { ...old, ...parsed.old };
  } catch {
    /* ignore */
  }
  Astro.cookies.delete('ldl_reg_err', { path: '/' });
}

const decorHtml = renderDecor('index');
---
<Layout title={`${APP_NAME} - Registro`} bodyClass="page-index">
  <div set:html={decorHtml} />
  <div class="container">
    <div class="header">
      <div class="logo-wrap">
        <img src="/assets/logo.png" alt={APP_NAME} class="logo logo--trazo" width="200" />
      </div>
      <p class="header-slogan">¡Soñá y Ganá!</p>
    </div>
    {errors._form && <div class="alert alert-error">{errors._form}</div>}
    <div class="card">
      <h2>Registrate para participar</h2>
      <form method="POST" action="/api/register">
        <div class="form-group">
          <label>Nombre Completo <span class="required">*</span></label>
          <input
            type="text"
            name="full_name"
            value={old.full_name}
            placeholder="Ej: Juan Alberto Pérez"
            class={errors.full_name ? 'error' : ''}
          />
          {errors.full_name && <div class="error-text">{errors.full_name}</div>}
        </div>
        <div class="form-group">
          <label>Número de Identidad <span class="required">*</span></label>
          <input
            type="text"
            name="identity_number"
            value={old.identity_number}
            placeholder="Ej: 0801-1990-12345"
            class={errors.identity_number ? 'error' : ''}
          />
          {errors.identity_number && <div class="error-text">{errors.identity_number}</div>}
        </div>
        <div class="form-group">
          <label>Correo Electrónico <span class="optional">(opcional)</span></label>
          <input
            type="email"
            name="email"
            value={old.email}
            placeholder="Ej: correo@ejemplo.com"
            class={errors.email ? 'error' : ''}
          />
          {errors.email && <div class="error-text">{errors.email}</div>}
        </div>
        <div class="form-group">
          <label>Número de Teléfono <span class="required">*</span></label>
          <input
            type="tel"
            name="phone"
            value={old.phone}
            placeholder="Ej: 9999-9999"
            class={errors.phone ? 'error' : ''}
          />
          {errors.phone && <div class="error-text">{errors.phone}</div>}
        </div>
        <button type="submit" class="btn btn-primary">Participar en la Trivia</button>
      </form>
    </div>
  </div>
</Layout>
