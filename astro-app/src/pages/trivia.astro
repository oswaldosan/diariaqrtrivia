---
import Layout from '../layouts/Layout.astro';
import { APP_NAME } from '../lib/config';
import { escapeHtml } from '../lib/html';
import { renderDecor } from '../lib/decor';
import { getPool } from '../lib/db';
import { getTriviaCookie } from '../lib/session';

const trivia = await getTriviaCookie(Astro.cookies);
if (!trivia) return Astro.redirect('/');

const total = trivia.questionIds.length;
const idx = trivia.currentIndex;
if (idx >= total) return Astro.redirect('/result');

const fb = trivia.feedback;

let question: { question_text: string } | null = null;
let answers: { id: number; answer_text: string }[] = [];
let progress = 0;

if (fb) {
  progress = ((idx + 1) / total) * 100;
} else {
  const qid = trivia.questionIds[idx];
  const pool = getPool();
  const [qRows] = await pool.execute('SELECT question_text FROM questions WHERE id = ?', [qid]);
  question = (qRows as { question_text: string }[])[0];
  const [aRows] = await pool.execute(
    'SELECT id, answer_text FROM answers WHERE question_id = ? ORDER BY RAND()',
    [qid]
  );
  answers = aRows as { id: number; answer_text: string }[];
  progress = (idx / total) * 100;
}

const decorId = fb ? 'trivia-feedback' : 'trivia';
const decorHtml = renderDecor(decorId);
const bodyClass = fb
  ? `page-trivia page-trivia-feedback ${fb.gameOver ? 'page-trivia-gameover' : ''}`
  : 'page-trivia';
---

<Layout
  title={fb ? `${APP_NAME} - ¿Acertaste?` : `${APP_NAME} - Trivia`}
  bodyClass={bodyClass}
>
  <div set:html={decorHtml} />
  <div class="container">
    <div class="header">
      <div class="logo-wrap">
        <img src="/assets/logo.png" alt={APP_NAME} class="logo logo--trazo" width="200" />
      </div>
      <p class="header-slogan">¡Soñá y Ganá!</p>
    </div>

    {
      fb && (
        <div class={`card card--feedback ${fb.gameOver ? 'card--game-over' : ''}`}>
          <div class="question-counter">
            Pregunta {idx + 1} de {total}
          </div>
          <div class="progress-bar">
            <div class="fill" style={`width:${progress}%`} />
          </div>
          <div class="question-text">{fb.questionText}</div>
          <div
            class={`feedback-banner ${fb.isCorrect ? 'feedback-banner--ok' : 'feedback-banner--bad'}`}
          >
            {fb.gameOver ? (
              <>
                <span class="feedback-banner__icon" aria-hidden="true">
                  ✗
                </span>
                <div class="feedback-banner__stack">
                  <span class="feedback-banner__title">Perdiste</span>
                  <span class="feedback-banner__subtitle">
                    Un solo error termina la partida. No podés seguir.
                  </span>
                </div>
              </>
            ) : fb.isCorrect ? (
              <>
                <span class="feedback-banner__icon" aria-hidden="true">
                  ✓
                </span>
                <span class="feedback-banner__title">¡Correcto!</span>
              </>
            ) : (
              <>
                <span class="feedback-banner__icon" aria-hidden="true">
                  ✗
                </span>
                <span class="feedback-banner__title">Incorrecto</span>
              </>
            )}
          </div>
          <ul class="feedback-answers" role="list">
            {fb.answers.map((a) => {
              const isSel = a.id === fb.selectedAnswerId;
              const isOk = Number(a.is_correct) === 1;
              let cls = 'feedback-answer';
              if (isOk) cls += ' feedback-answer--correct';
              if (isSel && !isOk) cls += ' feedback-answer--wrong';
              if (isSel && isOk) cls += ' feedback-answer--picked feedback-answer--picked-good';
              return (
                <li class={cls}>
                  {isOk && <span class="feedback-answer__badge">Correcta</span>}
                  {isSel && isOk && (
                    <span class="feedback-answer__badge feedback-answer__badge--good">Tu respuesta</span>
                  )}
                  {isSel && !isOk && (
                    <span class="feedback-answer__badge feedback-answer__badge--bad">Tu respuesta</span>
                  )}
                  <span class="feedback-answer__text">{escapeHtml(a.answer_text)}</span>
                </li>
              );
            })}
          </ul>
          {!fb.isCorrect && (
            <div class="feedback-extra">
              <p class="feedback-extra__label">
                {fb.gameOver ? '💬 Por qué no era' : '💬 Tip'}
              </p>
              <p
                class="feedback-extra__text"
                set:html={
                  fb.explanation && String(fb.explanation).trim() !== ''
                    ? escapeHtml(String(fb.explanation)).replace(/\n/g, '<br />')
                    : escapeHtml('La opción correcta está marcada arriba.')
                }
              />
            </div>
          )}
          {fb.gameOver ? (
            <a href="/result" class="btn btn-primary feedback-continue-form">
              Ver resultado
            </a>
          ) : (
            <form method="POST" action="/api/trivia/continue" class="feedback-continue-form">
              <input type="hidden" name="continue_next" value="1" />
              <button type="submit" class="btn btn-primary">
                {idx + 1 >= total ? 'Ver resultado' : 'Siguiente pregunta'}
              </button>
            </form>
          )}
        </div>
      )
    }

    {
      !fb && question && (
        <div class="card">
          <div class="question-counter">
            Pregunta {idx + 1} de {total}
          </div>
          <div class="progress-bar">
            <div class="fill" style={`width:${progress}%`} />
          </div>
          <div class="question-text">{question.question_text}</div>
          <form method="POST" action="/api/trivia/answer">
            <div class="ux-stagger">
              {answers.map((a) => (
                <button type="submit" name="answer_id" value={String(a.id)} class="answer-option">
                  {a.answer_text}
                </button>
              ))}
            </div>
          </form>
        </div>
      )
    }

    <p class="playing-as">Jugando como: {trivia.userName}</p>
  </div>
</Layout>
